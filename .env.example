# PocketBase bind address.
# Use 127.0.0.1:8091 if you only want local-machine access.
PB_HTTP=0.0.0.0:8091

# Optional frontend override.
# Leave unset to auto-detect from browser origin in production.
# VITE_POCKETBASE_URL=

# PocketBase encryption key.
# Must be exactly 32 characters long.
PB_ENCRYPTION_KEY=CHANGE_ME_32_CHARACTERS_LONG!!!!
