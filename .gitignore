# PocketBase
# Commit PocketBase data snapshots for cross-device development.
# Ignore only runtime temp/lock files.
pb_data/*.db-shm
pb_data/*.db-wal
pb_data/*.db-journal
pb_data/.lock
pb_data/types.d.ts
backups/

# Node / Frontend build artifacts
node_modules/
**/node_modules/
dist/
**/dist/

# Env files (commit a .env.example instead)
.env
.env.*
.env.local
.env.*.local
!.env.example

# General
.DS_Store
Thumbs.db
*.log
