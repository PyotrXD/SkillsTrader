{
  "scripts": {
    "setup": "npm ci && npm --prefix skillstrader-frontend ci",
    "setup:frontend": "npm --prefix skillstrader-frontend ci",
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "npm --prefix skillstrader-frontend run dev",
    "build": "npm --prefix skillstrader-frontend run build",
    "package:win": "node scripts/package-release.mjs --target win",
    "package:linux": "node scripts/package-release.mjs --target linux",
    "package:all": "node scripts/package-release.mjs --build --targets=win,linux",
    "lint": "npm --prefix skillstrader-frontend run lint",
    "preview": "npm --prefix skillstrader-frontend run preview"
  },
  "dependencies": {
    "pocketbase": "^0.26.8",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.1"
  }
}
