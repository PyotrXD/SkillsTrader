# Optional explicit PocketBase URL (recommended when frontend and API are on different hosts).
# Leave unset to auto-detect:
# - production: browser origin
# - development: browser host on VITE_POCKETBASE_PORT
# VITE_POCKETBASE_URL=

# Dev fallback PocketBase port when URL is not explicitly set.
VITE_POCKETBASE_PORT=8091

# Vite dev/preview network bindings.
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
VITE_PREVIEW_HOST=0.0.0.0
VITE_PREVIEW_PORT=4173

